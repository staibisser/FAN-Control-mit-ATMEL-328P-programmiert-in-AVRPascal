	(text_box "    //Bedingungen zum Einschalten\n    if ((GEon = 1) or (LastGoodTemp > TempFan) or (Taster)) then\n    begin\n      SchieberOnOff:= TRUE;\n    end;\n\n    //Bedingungen zum Ausschalten\n    if ((GEon = 0) and (LastGoodTemp < TempFan) and (not (Taster))) then\n    begin\n      SchieberOnOff:= False;\n    end;                     "
